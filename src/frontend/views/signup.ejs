<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/signup.css">
    <title>sign up</title>
</head>

<body>
    <nav class="signup__nav">
        <img src="/images/matchreact-logo.png" alt="matchreact logo" title="matchreact logo">
    </nav>

    <form class="signup__form" action="/signup" method="POST">
        <div class="signup__form--title">
            <h1>create a free account</h1>
            <p>start your match react journey!</p>
        </div>

        <div class="signup__form--forms">
            <div>
                <label>username</label>
                <input type="text" name="username" placeholder="enter your username" minlength="3" maxlength="20" required>
            </div>

            <div>
                <label>favorite club</label>
                <input type="text" name="club" placeholder="enter your favorite club" minlength="3" maxlength="10" required>
            </div>

            <div>
                <label>email address</label>
                <input type="email" name="email" placeholder="enter your email address" required>
            </div>

            <div>
                <label>password</label>
                <input type="password" name="password" placeholder="enter your password" minlength="8" maxlength="32" required>
            </div>
        </div>

        <button class="signup__form--button" type="submit">sign up</button>

        <div class="signup__form--link">
            <p>already have an account?</p>
            <a href="/login">log in here</a>
        </div>
    </form>
</body>

</html>